# --- Public (exposed to browser) — set per Vercel project / demo ---
NEXT_PUBLIC_SITE_NAME=Plumbers
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_LOGO_PATH=/brand/site-logo.svg
NEXT_PUBLIC_LOGO_ALT=Plumbers logo
NEXT_PUBLIC_SITE_TAGLINE=Quality boiler installations with transparent pricing and expert service.
NEXT_PUBLIC_FOOTER_LEGAL_LINE=Gas Safe registered engineers. Replace with your trading details.
NEXT_PUBLIC_FOOTER_LINKS_HEADING=Company
NEXT_PUBLIC_OG_IMAGE_ALT=Plumbers — boiler installation estimates
NEXT_PUBLIC_BUSINESS_DESCRIPTION=Boiler installations, servicing and repairs with transparent pricing.
# Optional E.164 for JSON-LD, e.g. +441234567890
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_LEGAL_ENTITY_NAME=Your Company Ltd
# Optional: only loads Meta Pixel when set
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
# Optional: localStorage key for quote wizard (per client if multiple sites)
NEXT_PUBLIC_QUOTE_WIZARD_STORAGE_KEY=

# --- Server only ---
SITE_BASE_URL=http://localhost:3000
MAIL_FROM=Plumbers <noreply@example.com>
# Used by lead/enquiry Resend sends when RESEND_API_KEY is set
FROM_EMAIL=Plumbers <noreply@example.com>
INSTALLER_EMAIL=installer@example.com
